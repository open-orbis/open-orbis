%% techResume template — pdfLaTeX
%% Based on alexcalabrese/techResume (MIT)
%% Jinja2 delimiters: << var >>, <% block %>, <# comment #>

\documentclass[10pt, a4paper]{cv}

\begin{document}

\personalinfo{%
  \name{<< person.name | default("") >>}
  <% if person.headline | default("") %>\tagline{<< person.headline >>}<% endif %>
  <% if person.email | default("") %>\email{<< person.email >>}<% endif %>
  <% if person.phone | default("") %>\phone{<< person.phone >>}<% endif %>
  <% if person.location | default("") %>\location{<< person.location >>}<% endif %>
}

\makecvheader

<% if person.summary | default("") %>
\cvsection{Summary}
<< person.summary >>
\medskip
<% endif %>

<# ── Work Experience ── #>
<% set work = nodes | selectattr("_type", "equalto", "WorkExperience") | list %>
<% if work %>
\cvsection{Experience}
<% for item in work %>
\cvevent{<< item.title | default("") >>}{<< item.company | default("") >>}{<< item.start_date | default("") >><% if item.end_date | default("") %> -- << item.end_date >><% endif %>}{<< item.location | default("") >>}
<% if item.description | default("") %>
\begin{itemize}
  \item << item.description >>
\end{itemize}
<% endif %>
\divider
<% endfor %>
<% endif %>

<# ── Education ── #>
<% set edu = nodes | selectattr("_type", "equalto", "Education") | list %>
<% if edu %>
\cvsection{Education}
<% for item in edu %>
\cvevent{<< item.degree | default("") >>}{<< item.institution | default("") >>}{<< item.start_date | default("") >><% if item.end_date | default("") %> -- << item.end_date >><% endif %>}{<< item.location | default("") >>}
<% if item.description | default("") %>
\begin{itemize}
  \item << item.description >>
\end{itemize}
<% endif %>
\divider
<% endfor %>
<% endif %>

<# ── Skills ── #>
<% set skills = nodes | selectattr("_type", "equalto", "Skill") | list %>
<% if skills %>
\cvsection{Skills}
<% for item in skills %>
\cvtag{<< item.name | default("") >>}
<% endfor %>
\medskip
<% endif %>

<# ── Languages ── #>
<% set langs = nodes | selectattr("_type", "equalto", "Language") | list %>
<% if langs %>
\cvsection{Languages}
<% for item in langs %>
\cvtag{<< item.name | default("") >><% if item.proficiency | default("") %> (<< item.proficiency >>)<% endif %>}
<% endfor %>
\medskip
<% endif %>

<# ── Projects ── #>
<% set projects = nodes | selectattr("_type", "equalto", "Project") | list %>
<% if projects %>
\cvsection{Projects}
<% for item in projects %>
\cvevent{<< item.name | default("") >>}{<< item.role | default("") >>}{}{}
<% if item.description | default("") %>
\begin{itemize}
  \item << item.description >>
\end{itemize}
<% endif %>
\divider
<% endfor %>
<% endif %>

<# ── Publications ── #>
<% set pubs = nodes | selectattr("_type", "equalto", "Publication") | list %>
<% if pubs %>
\cvsection{Publications}
<% for item in pubs %>
\cvevent{<< item.title | default("") >>}{<< item.venue | default("") >>}{<< item.date | default("") >>}{}
<% if item.abstract | default("") %>
\begin{itemize}
  \item << item.abstract >>
\end{itemize}
<% endif %>
\divider
<% endfor %>
<% endif %>

<# ── Certifications ── #>
<% set certs = nodes | selectattr("_type", "equalto", "Certification") | list %>
<% if certs %>
\cvsection{Certifications}
<% for item in certs %>
\cvevent{<< item.name | default("") >>}{<< item.issuing_organization | default("") >>}{<< item.date | default("") >>}{}
\divider
<% endfor %>
<% endif %>

<# ── Awards ── #>
<% set awards = nodes | selectattr("_type", "equalto", "Award") | list %>
<% if awards %>
\cvsection{Awards}
<% for item in awards %>
\cvevent{<< item.name | default("") >>}{<< item.issuing_organization | default("") >>}{<< item.date | default("") >>}{}
<% if item.description | default("") %>
\begin{itemize}
  \item << item.description >>
\end{itemize}
<% endif %>
\divider
<% endfor %>
<% endif %>

\end{document}
