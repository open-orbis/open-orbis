%% YAAC — Yet Another Awesome CV template — LuaLaTeX
%% Based on darwiin/yaac-another-awesome-cv (LPPL-1.3c)
%% Jinja2 delimiters: << var >>, <% block %>, <# comment #>

\documentclass[localFont]{yaac-another-awesome-cv}

\name{<< person.name | default("") >>}{}
\tagline{<< person.headline | default("") >>}

\socialinfo{%
  <% if person.email | default("") %>\email{<< person.email >>}<% endif %>
  <% if person.phone | default("") %>\smartphone{<< person.phone >>}<% endif %>
  <% if person.location | default("") %>\address{<< person.location >>}<% endif %>
}

\begin{document}

\makecvheader

<% if person.summary | default("") %>
\sectionTitle{Summary}{\faStar}
\begin{flushleft}
<< person.summary >>
\end{flushleft}
<% endif %>

<# ── Work Experience ── #>
<% set work = nodes | selectattr("_type", "equalto", "WorkExperience") | list %>
<% if work %>
\sectionTitle{Experience}{\faBriefcase}
\begin{experiences}
<% for item in work %>
  \experience
    {<< item.start_date | default("") >><% if item.end_date | default("") %> -- << item.end_date >><% endif %>}
    {<< item.title | default("") >>}
    {<< item.company | default("") >>}
    {<< item.location | default("") >>}
    {<< item.description | default("") >>}
<% endfor %>
\end{experiences}
<% endif %>

<# ── Education ── #>
<% set edu = nodes | selectattr("_type", "equalto", "Education") | list %>
<% if edu %>
\sectionTitle{Education}{\faGraduationCap}
\begin{experiences}
<% for item in edu %>
  \experience
    {<< item.start_date | default("") >><% if item.end_date | default("") %> -- << item.end_date >><% endif %>}
    {<< item.degree | default("") >>}
    {<< item.institution | default("") >>}
    {<< item.location | default("") >>}
    {<< item.description | default("") >>}
<% endfor %>
\end{experiences}
<% endif %>

<# ── Skills ── #>
<% set skills = nodes | selectattr("_type", "equalto", "Skill") | list %>
<% if skills %>
\sectionTitle{Skills}{\faWrench}
\begin{skills}
<% for item in skills %>
  \skill{<< item.name | default("") >>}{<< item.proficiency | default("3") >>}
<% endfor %>
\end{skills}
<% endif %>

<# ── Languages ── #>
<% set langs = nodes | selectattr("_type", "equalto", "Language") | list %>
<% if langs %>
\sectionTitle{Languages}{\faLanguage}
\begin{skills}
<% for item in langs %>
  \skill{<< item.name | default("") >>}{<< item.proficiency | default("3") >>}
<% endfor %>
\end{skills}
<% endif %>

<# ── Projects ── #>
<% set projects = nodes | selectattr("_type", "equalto", "Project") | list %>
<% if projects %>
\sectionTitle{Projects}{\faLaptop}
\begin{experiences}
<% for item in projects %>
  \experience
    {}
    {<< item.name | default("") >>}
    {<< item.role | default("") >>}
    {}
    {<< item.description | default("") >>}
<% endfor %>
\end{experiences}
<% endif %>

<# ── Publications ── #>
<% set pubs = nodes | selectattr("_type", "equalto", "Publication") | list %>
<% if pubs %>
\sectionTitle{Publications}{\faBook}
\begin{experiences}
<% for item in pubs %>
  \experience
    {<< item.date | default("") >>}
    {<< item.title | default("") >>}
    {<< item.venue | default("") >>}
    {}
    {<< item.abstract | default("") >>}
<% endfor %>
\end{experiences}
<% endif %>

<# ── Certifications ── #>
<% set certs = nodes | selectattr("_type", "equalto", "Certification") | list %>
<% if certs %>
\sectionTitle{Certifications}{\faCertificate}
\begin{experiences}
<% for item in certs %>
  \experience
    {<< item.date | default("") >>}
    {<< item.name | default("") >>}
    {<< item.issuing_organization | default("") >>}
    {}
    {}
<% endfor %>
\end{experiences}
<% endif %>

<# ── Awards ── #>
<% set awards = nodes | selectattr("_type", "equalto", "Award") | list %>
<% if awards %>
\sectionTitle{Awards}{\faTrophy}
\begin{experiences}
<% for item in awards %>
  \experience
    {<< item.date | default("") >>}
    {<< item.name | default("") >>}
    {<< item.issuing_organization | default("") >>}
    {}
    {<< item.description | default("") >>}
<% endfor %>
\end{experiences}
<% endif %>

\end{document}
