# GCP Configuration — Orbis Production
# Source this file before running setup/deploy scripts

export PROJECT_ID="open-orbis"
export REGION="europe-west1"
export ZONE="europe-west1-b"

# Service names
export BACKEND_SERVICE="orbis-api"
export MCP_SERVICE="orbis-mcp"
export SERVICE_ACCOUNT="orbis-api"
export VPC_CONNECTOR="orbis-connector"
export CONNECTOR_SUBNET="orbis-connector-subnet"
export NEO4J_VM="orbis-neo4j"
export SQL_INSTANCE="orbis-db"
export GCS_BUCKET="orbis-cv-files"
export AR_REPO="orbis"

# Neo4j VM
export NEO4J_MACHINE_TYPE="e2-standard-4"
export NEO4J_INTERNAL_IP="10.132.0.2"

# Cloud SQL
export SQL_TIER="db-f1-micro"
export SQL_PRIVATE_IP="10.42.0.3"

# LLM — Gemini Pro default, Claude Opus when quota approved
export DEFAULT_LLM_MODEL="gemini-2.5-pro"
export FALLBACK_CHAIN="gemini-pro"
# When Claude quota is approved, change to:
# export FALLBACK_CHAIN="claude-opus,gemini-pro"
