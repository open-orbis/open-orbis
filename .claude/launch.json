{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Neo4j",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "-d"],
      "port": 7687,
      "autoPort": false
    },
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd backend && source .venv/bin/activate && uvicorn app.main:app --reload --port 8000"],
      "port": 8000
    },
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend"],
      "port": 5173
    }
  ]
}
