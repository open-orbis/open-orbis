# Backend API base (default '/api' uses the Vite proxy; for a prod build
# pointing at a different origin, set this to the API URL).
VITE_API_URL=

# Google OAuth client ID (from Google Cloud Console).
VITE_GOOGLE_CLIENT_ID=

# LinkedIn OAuth client ID (from LinkedIn Developers).
VITE_LINKEDIN_CLIENT_ID=

# MCP server streamable-http endpoint. In dev, the MCP server runs on
# :8081 next to the API (:8000). In prod this points at Cloud Run.
VITE_MCP_URL=http://localhost:8081/mcp
